# Environment Variables
# Copy this file to .env.local and fill in your values

# Qdrant Cloud — https://cloud.qdrant.io (free tier, no credit card needed)
QUADRANT_CLUSTER_END_POINT=https://your-cluster.cloud.qdrant.io
QUADRANT_API_KEY=your_qdrant_api_key

# OpenRouter — https://openrouter.ai (for LLM and embeddings)
OPENROUTER_API_KEY=sk-or-v1-your_openrouter_api_key

# LLM Model (optional — defaults to openai/gpt-4.1-mini)
# Browse models at https://openrouter.ai/models
OPENROUTER_MODEL=openai/gpt-4.1-mini
