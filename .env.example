# Environment Variables
# Copy this file to .env.local and fill in your values

# == Required: Qdrant Cloud ==
# https://cloud.qdrant.io (free tier, no credit card needed)
QUADRANT_CLUSTER_END_POINT=https://your-cluster.cloud.qdrant.io
QUADRANT_API_KEY=your_qdrant_api_key

# == Required: OpenRouter (for LLM and embeddings) ==
# https://openrouter.ai
OPENROUTER_API_KEY=sk-or-v1-your_openrouter_api_key

# == Optional: LLM Model Selection ==
# Browse models at https://openrouter.ai/models
OPENROUTER_MODEL=openai/gpt-4.1-mini

# == Optional: RAG Pipeline Stage Controls ==
# Set to "true" to enable each advanced RAG technique
RAG_ENABLE_QUERY_REWRITE=true
RAG_ENABLE_QUERY_EXPANSION=false
RAG_ENABLE_SUB_QUERY=false
RAG_ENABLE_HYDE=false
RAG_ENABLE_RERANK=true
RAG_ENABLE_CORRECTIVE=true

# == Optional: Sub-Task Model Selection ==
# Use smaller/cheaper models for sub-tasks to reduce latency/cost
RAG_REWRITER_MODEL=openai/gpt-4.1-mini
RAG_JUDGE_MODEL=openai/gpt-4.1-mini
RAG_RERANKER_MODEL=openai/gpt-4.1-mini
